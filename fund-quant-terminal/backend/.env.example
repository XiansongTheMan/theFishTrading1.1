# =====================================================
# fund-quant-terminal 环境变量
# 复制为 .env 并填入实际配置
# =====================================================

# ------------- MongoDB -------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=fund_quant

# ------------- Tushare（可选）-------------
# 在 https://tushare.pro 注册获取 Token
# 不填时数据接口使用 AKShare 或返回占位
TUSHARE_TOKEN=

# ------------- 应用 -------------
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ------------- CORS -------------
# 逗号分隔的前端地址；设为 * 允许所有源（开发方便，生产慎用）
# 不设 * 时，会自动匹配 localhost/127.0.0.1 任意端口
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ------------- 华尔街见闻（供 Grok 决策参考的股市情报）-------------
WALLSTREETCN_BASE_URL=https://api-one.wallstcn.com

# ------------- LLM 多模型配置（MultiLLMClient 统一调用）-------------
# Grok (x.ai)：在 https://console.x.ai 获取 API Key
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# Qwen / 通义千问（DashScope OpenAI 兼容）：在 https://dashscope.console.aliyun.com 获取
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认模型与生成参数
# DEFAULT_MODEL: grok-4-fast-reasoning 或 qwen-turbo 等
# LLM_PROVIDER: grok 或 qwen
DEFAULT_MODEL=grok-4-fast-reasoning
DEFAULT_TEMPERATURE=0.2
MAX_TOKENS=2000
LLM_PROVIDER=grok
